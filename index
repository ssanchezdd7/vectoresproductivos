const fmt = new Intl.NumberFormat('es-AR', {maximumFractionDigits:1});
const fmt0 = new Intl.NumberFormat('es-AR', {maximumFractionDigits:0});
const colors = ['#7b4dff','#49d3ff','#ff6ea9','#7ef2c1','#ffd166','#b69cff','#8bd3ff','#e3d5ff','#faf3dd'];
let charts = {};
function unique(arr){return [...new Set(arr)]}
function selectedProvinces(){
  const vals=[...document.getElementById('provincia').selectedOptions].map(o=>o.value);
  return vals.length?vals:['San Juan'];
}
function getProvYear(p,y){return DATA.provYear.find(d=>d.provincia===p && d.anio===+y)}
function getCats(p,y){return DATA.categories.filter(d=>d.provincia===p && d.anio===+y).sort((a,b)=>b.share-a.share)}
function avg(arr, field){const xs=arr.map(d=>d?.[field]).filter(v=>v!=null); return xs.length?xs.reduce((a,b)=>a+b,0)/xs.length:null}
function sum(arr, field){const xs=arr.map(d=>d?.[field]).filter(v=>v!=null); return xs.reduce((a,b)=>a+b,0)}
function init(){
  const psel=document.getElementById('provincia');
  DATA.provinces.forEach(p=>{let o=document.createElement('option'); o.value=p; o.textContent=p; if(p==='San Juan') o.selected=true; psel.appendChild(o);});
  const vectors=unique(DATA.categories.map(d=>d.vector)).sort();
  const vsel=document.getElementById('vector');
  vectors.forEach(v=>{let o=document.createElement('option'); o.value=v; o.textContent=v; vsel.appendChild(o);});
  ['provincia','anioDesde','anioHasta','vector','perfil','indicador'].forEach(id=>document.getElementById(id).addEventListener('input', update));
  update();
}
function profileFilter(rows, perfil){
  if(perfil==='todos') return rows;
  if(perfil==='minero') return rows.filter(r=>r.share_mineria>=3);
  if(perfil==='proveedor') { const sorted=[...rows].sort((a,b)=>b.indice-a.indice); const cutoff=sorted[Math.floor(sorted.length*.35)]?.indice || 0; return rows.filter(r=>r.indice>=cutoff); }
  if(perfil==='diversificado') return rows.filter(r=>r.concentracion_top3<55);
  return rows;
}
function aggregateCats(provs,y,vector){
  const map={};
  provs.forEach(p=>getCats(p,y).forEach(c=>{if(vector!=='Todos'&&c.vector!==vector) return; map[c.vector]=(map[c.vector]||[]); map[c.vector].push(c.share);}));
  return Object.entries(map).map(([vector,vals])=>({vector, share:vals.reduce((a,b)=>a+b,0)/vals.length})).sort((a,b)=>b.share-a.share);
}
function update(){
  const provs=selectedProvinces();
  let y0=+document.getElementById('anioDesde').value;
  let y1=+document.getElementById('anioHasta').value;
  if(y0>y1){ const tmp=y0; y0=y1; y1=tmp; }
  const v=document.getElementById('vector').value, perfil=document.getElementById('perfil').value, indicador=document.getElementById('indicador').value;
  document.getElementById('periodoTxt').textContent=`Período: ${y0}-${y1}. Los KPI y rankings leen el año final; la evolución muestra todo el período.`;
  const pys=provs.map(p=>getProvYear(p,y1)).filter(Boolean);
  document.getElementById('kpiVab').textContent=fmt0.format(sum(pys,'total'));
  document.getElementById('kpiIndice').textContent=fmt.format(avg(pys,'indice'));
  document.getElementById('kpiMineria').textContent=fmt.format(avg(pys,'share_mineria'))+'%';
  document.getElementById('kpiConc').textContent=fmt.format(avg(pys,'concentracion_top3'))+'%';
  const cats=aggregateCats(provs,y1,v);
  drawBar('barCat', cats.map(c=>c.vector), cats.map(c=>c.share), '% del VAB');
  drawSupplierTrend(provs,y0,y1);
  drawVabTrend(provs,y0,y1);
  let rows=profileFilter(DATA.provYear.filter(d=>d.anio===y1),perfil).sort((a,b)=>(b[indicador]||0)-(a[indicador]||0)).slice(0,10);
  drawBar('rankIndice', rows.map(d=>d.provincia), rows.map(d=>d[indicador]), labelIndicador(indicador), true);
  topTable(provs,y1);
  narrative(provs,y0,y1,pys,cats,indicador);
}
function labelIndicador(i){return {indice:'Índice proveedor', share_mineria:'Participación minera (%)', concentracion_top3:'Concentración top 3 (%)', total:'VAB'}[i]||i}
function drawBar(id, labels, values, label, horizontal=false){
  if(charts[id]) charts[id].destroy();
  charts[id]=new Chart(document.getElementById(id), {type:'bar', data:{labels, datasets:[{label, data:values, backgroundColor: labels.map((_,i)=>colors[i%colors.length]), borderRadius:10}]}, options:{indexAxis:horizontal?'y':'x', responsive:true, plugins:{legend:{display:false}, tooltip:{callbacks:{label:(ctx)=>`${label}: ${fmt.format(ctx.raw)}${label.includes('%')?'%':''}`}}}, scales:{x:{ticks:{color:'#c8c2e5'}, grid:{color:'rgba(255,255,255,.08)'}}, y:{ticks:{color:'#c8c2e5'}, grid:{color:'rgba(255,255,255,.08)'}}}} });
}
function drawSupplierTrend(provs,y0,y1){
  if(charts.lineTotal) charts.lineTotal.destroy();
  const years=unique(DATA.provYear.map(d=>d.anio)).filter(a=>a>=y0 && a<=y1).sort((a,b)=>a-b);
  const datasets=provs.map((p,i)=>{
    const vals=years.map(a=>{const row=getProvYear(p,a); return row?row.indice:null;});
    return {label:p, data:vals, borderColor:colors[i%colors.length], backgroundColor:'rgba(73,211,255,.10)', fill:false, tension:.35, pointRadius:years.length<=2?5:2};
  });
  charts.lineTotal=new Chart(document.getElementById('lineTotal'), {type:'line', data:{labels:years, datasets}, options:{responsive:true, plugins:{legend:{labels:{color:'#f7f5ff'}}}, scales:{x:{ticks:{color:'#c8c2e5'}, grid:{color:'rgba(255,255,255,.08)'}}, y:{title:{display:true,text:'Índice proveedor',color:'#c8c2e5'}, ticks:{color:'#c8c2e5'}, grid:{color:'rgba(255,255,255,.08)'}}}} });
}
function drawVabTrend(provs,y0,y1){
  if(charts.lineVab) charts.lineVab.destroy();
  const years=unique(DATA.provYear.map(d=>d.anio)).filter(a=>a>=y0 && a<=y1).sort((a,b)=>a-b);
  const datasets=provs.map((p,i)=>{
    const vals=years.map(a=>{const row=getProvYear(p,a); return row?row.total:null;});
    return {label:p, data:vals, borderColor:colors[(i+2)%colors.length], backgroundColor:'rgba(123,77,255,.10)', fill:false, tension:.35, pointRadius:years.length<=2?5:2};
  });
  charts.lineVab=new Chart(document.getElementById('lineVab'), {type:'line', data:{labels:years, datasets}, options:{responsive:true, plugins:{legend:{labels:{color:'#f7f5ff'}}, tooltip:{callbacks:{label:(ctx)=>`${ctx.dataset.label}: ${fmt0.format(ctx.raw)} millones`}}}, scales:{x:{ticks:{color:'#c8c2e5'}, grid:{color:'rgba(255,255,255,.08)'}}, y:{title:{display:true,text:'Millones de pesos de 2004',color:'#c8c2e5'}, ticks:{color:'#c8c2e5'}, grid:{color:'rgba(255,255,255,.08)'}}}} });
}
function topTable(provs,y){
 const map={};
 provs.forEach(p=>DATA.topSectors.filter(d=>d.provincia===p).forEach(r=>{map[r.sector]=map[r.sector]||[]; map[r.sector].push(r.share)}));
 const rows=Object.entries(map).map(([sector,vals])=>({sector, share:vals.reduce((a,b)=>a+b,0)/vals.length})).sort((a,b)=>b.share-a.share).slice(0,8);
 document.getElementById('topSectors').innerHTML=rows.map(r=>`<tr><td>${r.sector}</td><td>${fmt.format(r.share)}%</td></tr>`).join('');
}
function narrative(provs,y0,y1,pys,cats,indicador){
 const title=provs.length===1?provs[0]:`${provs.length} provincias seleccionadas`;
 const top=cats[0]; const ind=avg(pys,'indice'), min=avg(pys,'share_mineria'), conc=avg(pys,'concentracion_top3');
 let perfil = min>=3 ? 'perfil con presencia minera directa relevante' : (ind>=10 ? 'base proveedora potencialmente significativa' : 'matriz con encadenamientos selectivos');
 let msg=`<p><b>${title}</b> muestra al cierre del período ${y0}-${y1} un ${perfil}. El vector dominante de la selección es <b>${top?.vector||'s/d'}</b> (${fmt.format(top?.share||0)}%).</p>`;
 msg+=`<p>La evolución del índice proveedor y del VAB se presentan como gráficos de líneas para el período seleccionado. El indicador de comparación activo es <b>${labelIndicador(indicador)}</b>.</p>`;
 msg+=`<p>Para política pública, la señal clave es combinar minería directa con capacidades proveedoras: construcción, metalmecánica, transporte, servicios técnicos, comercio especializado, energía, hotelería y gastronomía. Las brechas prioritarias son certificación, escala, financiamiento, calidad, trazabilidad y articulación con empresas tractoras.</p>`;
 document.getElementById('narrativa').innerHTML=msg;
}
init();
</script>
